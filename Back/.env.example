# Copia este archivo a `.env` y ajusta los valores.

# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Turso (libSQL) — credenciales de tu base
#   turso db show <tu-base> --url       -> TURSO_DATABASE_URL
#   turso db tokens create <tu-base>    -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL="libsql://tu-base-xxxxx.turso.io"
TURSO_AUTH_TOKEN="tu-token-de-turso"

# Solo lo usa el CLI de Prisma (generate/studio). En runtime se ignora (se usa Turso).
# Apúntalo a un archivo SQLite local cualquiera.
DATABASE_URL="file:./prisma/local.db"

# JWT — cambia esto en producción por algo aleatorio largo
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=7d
